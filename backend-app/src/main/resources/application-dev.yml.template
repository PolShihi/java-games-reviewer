spring:
  datasource:
    url: jdbc:postgresql://localhost:5432/game_reviewer
    username: postgres
    password: YOUR_PASSWORD_HERE
    driver-class-name: org.postgresql.Driver
    hikari:
      maximum-pool-size: 5
      minimum-idle: 2
      connection-timeout: 30000
      idle-timeout: 600000
      max-lifetime: 1800000
  
  jpa:
    show-sql: true
    properties:
      hibernate:
        format_sql: true
        use_sql_comments: true

logging:
  level:
    root: INFO
    com.project.gamereviewer: DEBUG
    org.springframework.web: DEBUG
    org.hibernate.SQL: DEBUG
    org.hibernate.type.descriptor.sql.BasicBinder: TRACE
  file:
    name: logs/game-reviewer-dev.log
    max-size: 10MB
    max-history: 7

server:
  port: 8080
  error:
    include-stacktrace: always
